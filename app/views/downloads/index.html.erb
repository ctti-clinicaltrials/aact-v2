<% content_for :title, "Downloads — AACT" %>

<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">AACT Database Downloads</h1>
  <p class="mt-2 text-gray-600">Download the latest snapshots of the AACT database in your preferred format.</p>
</div>

<% if @latest_snapshots.present? %>
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <% @latest_snapshots.each do |snapshot| %>
      <%= render "snapshot_card", snapshot: snapshot %>
    <% end %>
  </div>
<% else %>
  <%= render "empty_state",
    title: "No Snapshots Available",
    message: "We couldn't retrieve the latest database snapshots at this time. Please try again later." %>
<% end %>

<div class="mt-10 border-t border-gray-200 pt-8">
  <h2 class="text-lg font-semibold text-gray-700 mb-4">Additional Resources</h2>
  <div class="flex gap-4">
    <%= link_to "View Documentation", documentation_index_path, class: "text-sm text-blue-600 hover:underline" %>
  </div>
</div>
