<div class="bg-gray-50 -mx-4 sm:-mx-6 lg:-mx-8 -my-8 px-4 sm:px-6 lg:px-8 py-8">
  <div class="max-w-7xl mx-auto">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Settings</h1>
      <p class="mt-1 text-sm text-gray-600">Manage your account settings and preferences</p>
    </div>

    <div class="grid grid-cols-12 gap-x-8">
      <!-- Sidebar Navigation -->
      <aside class="col-span-3">
        <nav class="space-y-1 bg-white rounded-lg shadow-sm p-4">
          <%= link_to settings_profile_path, 
                class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{current_page?(settings_profile_path) ? 'bg-blue-50 text-blue-700' : 'text-gray-700 hover:bg-gray-50'}" do %>
            <svg class="flex-shrink-0 -ml-1 mr-3 h-5 w-5 #{current_page?(settings_profile_path) ? 'text-blue-500' : 'text-gray-400 group-hover:text-gray-500'}" 
                 fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <span>Profile</span>
          <% end %>

          <%= link_to settings_password_path, 
                class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{current_page?(settings_password_path) ? 'bg-blue-50 text-blue-700' : 'text-gray-700 hover:bg-gray-50'}" do %>
            <svg class="flex-shrink-0 -ml-1 mr-3 h-5 w-5 #{current_page?(settings_password_path) ? 'text-blue-500' : 'text-gray-400 group-hover:text-gray-500'}" 
                 fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
            </svg>
            <span>Password</span>
          <% end %>

          <%= link_to settings_database_access_path, 
                class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{current_page?(settings_database_access_path) ? 'bg-blue-50 text-blue-700' : 'text-gray-700 hover:bg-gray-50'}" do %>
            <svg class="flex-shrink-0 -ml-1 mr-3 h-5 w-5 #{current_page?(settings_database_access_path) ? 'text-blue-500' : 'text-gray-400 group-hover:text-gray-500'}" 
                 fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
            </svg>
            <span>Database Access</span>
          <% end %>

          <div class="border-t border-gray-200 my-4"></div>

          <%= button_to session_path, method: :delete, 
                class: "group w-full flex items-center px-3 py-2 text-sm font-medium rounded-md text-gray-700 hover:bg-gray-50" do %>
            <svg class="flex-shrink-0 -ml-1 mr-3 h-5 w-5 text-gray-400 group-hover:text-gray-500" 
                 fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            <span>Log out</span>
          <% end %>
        </nav>
      </aside>

      <!-- Main Content Area -->
      <div class="col-span-9">
        <!-- Flash Messages (Settings-scoped) -->
        <% if notice.present? %>
          <div class="mb-6 rounded-md bg-green-50 p-4 border-l-4 border-green-400" role="alert">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-green-800"><%= notice %></p>
              </div>
            </div>
          </div>
        <% end %>

        <% if alert.present? %>
          <div class="mb-6 rounded-md bg-red-50 p-4 border-l-4 border-red-400" role="alert">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-red-800"><%= alert %></p>
              </div>
            </div>
          </div>
        <% end %>

        <div class="bg-white rounded-lg shadow-sm p-6">
          <%= yield %>
        </div>
      </div>
    </div>
  </div>
</div>
