<%= render layout: "settings/layout" do %>
  <h2 class="text-xl font-semibold text-gray-900 mb-6">Update Password</h2>

  <p class="text-sm text-gray-600 mb-6">
    Ensure your account is using a long, random password to stay secure.
  </p>

<%= form_with url: settings_password_path, method: :patch, class: "space-y-6" do |form| %>
  <div>
    <%= form.label :current_password, "Current Password", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.password_field :current_password, 
          required: true, 
          autocomplete: "current-password",
          placeholder: "Enter your current password",
          class: "block w-full sm:w-96 px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div>
    <%= form.label :password, "New Password", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.password_field "user[password]", 
          required: true, 
          autocomplete: "new-password",
          placeholder: "Enter new password",
          maxlength: 72,
          class: "block w-full sm:w-96 px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div>
    <%= form.label :password_confirmation, "Confirm New Password", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.password_field "user[password_confirmation]", 
          required: true, 
          autocomplete: "new-password",
          placeholder: "Confirm new password",
          maxlength: 72,
          class: "block w-full sm:w-96 px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div class="flex items-center gap-4 pt-4">
    <%= form.submit "Update Password", 
          class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
    <%= link_to "Cancel", root_path, 
          class: "text-sm text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>

  <div class="mt-8 pt-8 border-t border-gray-200">
    <div class="flex items-start">
      <svg class="h-5 w-5 text-blue-500 mr-3 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div>
        <h4 class="text-sm font-medium text-gray-900">Password Requirements</h4>
        <ul class="mt-2 text-sm text-gray-600 space-y-1">
          <li>• Use a strong, unique password</li>
          <li>• Maximum 72 characters</li>
          <li>• Consider using a password manager</li>
        </ul>
      </div>
    </div>
  </div>
<% end %>
