<% content_for :title, "Database Access" %>

<!-- Auto-refresh page every 3 seconds if status is pending or processing -->
<% content_for :head do %>
  <% if @user.db_creation_pending? || @user.db_creation_processing? %>
    <meta http-equiv="refresh" content="3">
  <% end %>
<% end %>

<%= render layout: "settings/layout" do %>
  <div class="max-w-3xl">
    <h2 class="text-2xl font-semibold text-gray-900 mb-6">Database Access</h2>
    
    <!-- Turbo Frame wraps all dynamic content -->
    <%= turbo_frame_tag "database_setup" do %>
      
      <% if @user.db_creation_pending? || @user.db_creation_processing? %>
        <!-- Auto-refresh using JavaScript since meta tag doesn't work in Turbo Frames -->
        <script>
          setTimeout(() => { Turbo.visit(window.location, { frame: "database_setup" }); }, 3000);
        </script>
      <% end %>
      
      <% if @user.db_creation_not_requested? %>
        <!-- State 1: Not set up - Show direct database access option -->
        <div class="bg-white border border-gray-200 rounded-lg p-8 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4" />
          </svg>
          <h3 class="text-lg font-medium text-gray-900 mb-2">Need Direct Database Access?</h3>
          <p class="text-gray-600 mb-6">
            For advanced users who want to run complex queries or integrate with their own tools,
            set up read-only database credentials for direct PostgreSQL access.
          </p>
          <%= link_to "Set Up Database Access",
                      new_settings_database_access_path,
                      data: { turbo_frame: "database_setup" },
                      class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
        </div>
        
      <% elsif @user.db_creation_pending? || @user.db_creation_processing? %>
        <!-- State 2: Processing - Show spinner and message -->
        <div class="bg-blue-50 border-l-4 border-blue-400 p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="animate-spin h-5 w-5 text-blue-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-blue-800">Setting up your database access...</h3>
              <p class="mt-1 text-sm text-blue-700">This should only take a moment. This page will refresh automatically.</p>
            </div>
          </div>
        </div>
        
      <% elsif @user.db_creation_failed? %>
        <!-- State 3: Failed - Show error and retry button -->
        <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-6">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3 flex-1">
              <h3 class="text-sm font-medium text-red-800">Database setup failed</h3>
              <p class="mt-1 text-sm text-red-700"><%= @user.database_creation_error %></p>
              <div class="mt-4">
                <%= link_to "Try Again",
                            new_settings_database_access_path,
                            data: { turbo_frame: "database_setup" },
                            class: "inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md text-red-700 bg-red-100 hover:bg-red-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
              </div>
            </div>
          </div>
        </div>
        
      <% elsif @user.db_creation_completed? %>
        <!-- State 4: Completed - Show credentials (your existing code) -->
      <div class="mb-6 p-4 bg-green-50 border-l-4 border-green-400">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-green-800">Database access is set up</h3>
            <p class="mt-1 text-sm text-green-700">You have read-only access to the AACT public database.</p>
          </div>
        </div>
      </div>

      <div class="bg-white border border-gray-200 rounded-lg p-6 mb-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Connection Information</h3>
        
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Database Host:</label>
            <div class="flex items-center justify-between bg-gray-50 p-3 rounded border border-gray-300">
              <code class="text-sm text-gray-900">aact-db.ctti-clinicaltrials.org</code>
              <button onclick="copyText('aact-db.ctti-clinicaltrials.org')" class="text-blue-600 hover:text-blue-700 text-sm font-medium">Copy</button>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Port:</label>
            <div class="flex items-center justify-between bg-gray-50 p-3 rounded border border-gray-300">
              <code class="text-sm text-gray-900">5432</code>
              <button onclick="copyText('5432')" class="text-blue-600 hover:text-blue-700 text-sm font-medium">Copy</button>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Database Name:</label>
            <div class="flex items-center justify-between bg-gray-50 p-3 rounded border border-gray-300">
              <code class="text-sm text-gray-900">aact</code>
              <button onclick="copyText('aact')" class="text-blue-600 hover:text-blue-700 text-sm font-medium">Copy</button>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Username:</label>
            <div class="flex items-center justify-between bg-gray-50 p-3 rounded border border-gray-300">
              <code class="text-sm text-gray-900"><%= @user.database_username %></code>
              <button onclick="copyText('<%= @user.database_username %>')" class="text-blue-600 hover:text-blue-700 text-sm font-medium">Copy</button>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Password:</label>
            <div class="flex items-center justify-between bg-gray-50 p-3 rounded border border-gray-300">
              <code class="text-sm text-gray-900">••••••••••••</code>
              <%= link_to "Reveal", reveal_password_settings_database_access_path, class: "text-blue-600 hover:text-blue-700 text-sm font-medium" %>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
        <h4 class="font-medium text-blue-900 mb-2">How to connect:</h4>
        <ul class="text-sm text-blue-700 space-y-1">
          <li>• Use any PostgreSQL client (pgAdmin, DBeaver, DataGrip, etc.)</li>
          <li>• Enter the connection details above</li>
          <li>• Your access is read-only for security</li>
          <li>• Click "Reveal" to view your password (requires verification)</li>
        </ul>
      </div>

      <% end %>
      
    <% end %> <!-- End turbo_frame_tag -->
  </div>
<% end %>

<script>
function copyText(text) {
  navigator.clipboard.writeText(text).then(function() {
    console.log('Copied');
  });
}
</script>
