<% content_for :title, "Database Access" %>

<%= render layout: "settings/layout" do %>
  <div class="max-w-3xl">
    <h2 class="text-2xl font-semibold text-gray-900 mb-6">Database Access</h2>
    
    <!-- Turbo Frame wraps the swappable content area -->
    <%= turbo_frame_tag "database_setup" do %>
      
      <!-- Turbo Stream subscription for real-time status updates -->
      <%= turbo_stream_from "user_#{@user.id}_database_setup" %>
      
      <% if @user.db_creation_not_requested? %>
        <%= render "call_to_action" %>
        
      <% elsif @user.db_creation_pending? || @user.db_creation_processing? %>
        <!-- Status updates will replace this div via Turbo Streams -->
        <div id="database_status">
          <%= render "processing_status" %>
        </div>
        
      <% elsif @user.db_creation_failed? %>
        <div id="database_status">
          <%= render "error_status", user: @user %>
        </div>
        
      <% elsif @user.db_creation_completed? %>
        <%= render "credentials", user: @user %>
      <% end %>
      
    <% end %> <!-- End turbo_frame_tag -->
  </div>
<% end %>
