<!-- Frame-only content - no layout wrappers needed -->
<!-- Wrap form in matching Turbo Frame -->
<%= turbo_frame_tag "database_setup" do %>
  <div class="mb-6 p-4 bg-blue-50 border-l-4 border-blue-400">
    <div class="flex">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="ml-3">
        <p class="text-sm text-blue-700">
          Choose your database username and password.
          <strong>Save them securely</strong> - you'll need them to connect to the database.
          You can always view your credentials by entering your website password.
        </p>
      </div>
    </div>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg p-6">
    <%= form_with url: settings_database_access_path, method: :post, class: "space-y-4" do |form| %>
      <div>
        <label for="database_username" class="block text-sm font-medium text-gray-700 mb-2">
          Database Username:
        </label>
        <%= form.text_field :database_username,
              id: "database_username",
              placeholder: "Enter your preferred username",
              class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
              required: true %>
        <p class="mt-1 text-sm text-gray-500">This will be your PostgreSQL username.</p>
      </div>

      <div>
        <label for="database_password" class="block text-sm font-medium text-gray-700 mb-2">
          Database Password:
        </label>
        <%= form.password_field :database_password,
              id: "database_password",
              placeholder: "Enter your preferred password",
              class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
              required: true %>
        <p class="mt-1 text-sm text-gray-500">Choose a strong password for database access.</p>
      </div>

      <div class="flex gap-3 pt-4">
        <%= form.submit "Set Up Database Access",
              class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>

        <%= link_to settings_database_access_path,
              class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
          Cancel
        <% end %>
      </div>
    <% end %>
  </div>

<% end %> <!-- End turbo_frame_tag -->
