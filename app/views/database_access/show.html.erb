<% content_for :title, "Database Credentials" %>

<div class="max-w-md mx-auto mt-8">
  <div class="bg-white shadow-md rounded px-8 pt-6 pb-8 mb-4">
    <h2 class="text-2xl font-bold mb-6 text-gray-800">Database Credentials</h2>
    
    <% if @show_credentials %>

      <div class="space-y-4">
        <div>
          <label class="block text-gray-700 text-sm font-bold mb-2">
            Database Host:
          </label>
          <div class="bg-gray-100 p-3 rounded border">
            <code class="text-sm">138.197.80.22:5432</code>
          </div>
        </div>

        <div>
          <label class="block text-gray-700 text-sm font-bold mb-2">
            Database Name:
          </label>
          <div class="bg-gray-100 p-3 rounded border">
            <code class="text-sm">aact_public</code>
          </div>
        </div>

        <div>
          <label class="block text-gray-700 text-sm font-bold mb-2">
            Username:
          </label>
          <div class="bg-gray-100 p-3 rounded border flex justify-between items-center">
            <code class="text-sm"><%= @database_username %></code>
            <button onclick="copyToClipboard('<%= @database_username %>')" 
                    class="text-blue-500 hover:text-blue-700 text-sm">
              Copy
            </button>
          </div>
        </div>

        <div>
          <label class="block text-gray-700 text-sm font-bold mb-2">
            Password:
          </label>
          <div class="bg-gray-100 p-3 rounded border flex justify-between items-center">
            <code class="text-sm"><%= @database_password %></code>
            <button onclick="copyToClipboard('<%= @database_password %>')" 
                    class="text-blue-500 hover:text-blue-700 text-sm">
              Copy
            </button>
          </div>
        </div>

        <div class="mt-6 p-4 bg-yellow-50 border-l-4 border-yellow-400">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <p class="text-sm text-yellow-700">
                <strong>Security Note:</strong> Store these credentials securely. You can view them again by entering your password.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-6 text-center">
        <%= link_to "Back to Dashboard", root_path, 
              class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline" %>
      </div>

    <% else %>
      <!-- Password prompt to view credentials -->
      <div class="mb-6 p-4 bg-blue-50 border-l-4 border-blue-400">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M18 8a6 6 0 01-7.743 5.743L10 14l-1 1-1 1H6v2H2v-4l4.257-4.257A6 6 0 1118 8zm-6-4a1 1 0 100 2 2 2 0 012 2 1 1 0 102 0 4 4 0 00-4-4z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <p class="text-sm text-blue-700">
              <strong>Security:</strong> Enter your website password to view your database credentials.
            </p>
          </div>
        </div>
      </div>

      <%= form_with url: verify_database_access_path, method: :post, local: true, class: "space-y-4" do |form| %>
        <div>
          <%= form.label :password, "Your Account Password:", class: "block text-gray-700 text-sm font-bold mb-2" %>
          <%= form.password_field :password, 
                class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline",
                placeholder: "Enter your website password",
                required: true %>
        </div>

        <div class="flex items-center justify-between">
          <%= form.submit "View Credentials", 
                class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline w-full" %>
        </div>
      <% end %>

      <div class="mt-4 text-center">
        <%= link_to "Back to Dashboard", root_path, class: "text-blue-500 hover:text-blue-800 text-sm" %>
      </div>
    <% end %>
  </div>
</div>

<script>
function copyToClipboard(text) {
  navigator.clipboard.writeText(text).then(function() {
    // You could add a toast notification here
    console.log('Copied to clipboard');
  }, function(err) {
    console.error('Could not copy text: ', err);
  });
}
</script>