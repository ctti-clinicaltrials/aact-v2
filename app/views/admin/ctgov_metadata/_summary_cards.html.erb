<%= turbo_frame_tag "summary_cards" do %>
  <div class="grid grid-cols-4 gap-4 mb-4">
    <%= render StatCardComponent.new(label: "Total Snapshots", value: total_snapshots) %>
    <%= render StatCardComponent.new(label: "Latest Snapshot", value: latest_snapshot ? time_ago_in_words(latest_snapshot.created_at) : "Never") %>
    <%= render StatCardComponent.new(label: "Active Fields", value: active_fields_count) %>
    <%= render StatCardComponent.new(label: "Total Fields", value: total_fields_count) %>
  </div>
<% end %>
