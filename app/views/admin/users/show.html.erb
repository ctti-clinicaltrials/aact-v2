<div class="mx-auto max-w-4xl">
  <!-- Header -->
  <div class="flex items-center gap-4 mb-8">
    <button onclick="history.back()" class="px-4 py-2 bg-gray-200 text-gray-700 text-sm font-medium rounded-md hover:bg-gray-300">Back</button>
    <h1 class="text-2xl font-bold text-gray-900"><%= @user.name %></h1>
    <% if @user.admin? %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Admin</span>
    <% end %>
    <% if @user.migrated? %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Migrated</span>
    <% end %>
  </div>

  <!-- Account Info -->
  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <h2 class="text-sm font-medium text-gray-700 mb-4">Account Information</h2>
    <dl class="grid grid-cols-2 gap-x-8 gap-y-4">
      <div>
        <dt class="text-xs text-gray-500 uppercase">Email</dt>
        <dd class="text-sm text-gray-900 mt-1"><%= @user.email_address %></dd>
      </div>
      <div>
        <dt class="text-xs text-gray-500 uppercase">Joined</dt>
        <dd class="text-sm text-gray-900 mt-1"><%= @user.created_at.strftime("%B %d, %Y") %></dd>
      </div>
      <div>
        <dt class="text-xs text-gray-500 uppercase">Database Username</dt>
        <dd class="text-sm text-gray-900 mt-1">
          <% if @user.database_username.present? %>
            <code class="bg-gray-100 px-1.5 py-0.5 rounded text-xs"><%= @user.database_username %></code>
          <% else %>
            <span class="text-gray-400">Not set up</span>
          <% end %>
        </dd>
      </div>
      <div>
        <dt class="text-xs text-gray-500 uppercase">DB Access Status</dt>
        <dd class="text-sm text-gray-900 mt-1"><%= @user.database_creation_status.humanize %></dd>
      </div>
      <% if @user.metadata.present? %>
        <% if @user.metadata["confirmed_at"].present? %>
          <div>
            <dt class="text-xs text-gray-500 uppercase">Confirmed At</dt>
            <dd class="text-sm text-gray-900 mt-1"><%= @user.metadata["confirmed_at"] %></dd>
          </div>
        <% end %>
        <% if @user.metadata["sign_in_count"].present? %>
          <div>
            <dt class="text-xs text-gray-500 uppercase">Sign-in Count</dt>
            <dd class="text-sm text-gray-900 mt-1"><%= number_with_delimiter(@user.metadata["sign_in_count"]) %></dd>
          </div>
        <% end %>
        <% if @user.metadata["last_sign_in_at"].present? %>
          <div>
            <dt class="text-xs text-gray-500 uppercase">Last Sign-in</dt>
            <dd class="text-sm text-gray-900 mt-1"><%= @user.metadata["last_sign_in_at"] %></dd>
          </div>
        <% end %>
        <% if @user.metadata["last_sign_in_ip"].present? %>
          <div>
            <dt class="text-xs text-gray-500 uppercase">Last Sign-in IP</dt>
            <dd class="text-sm text-gray-900 mt-1"><%= @user.metadata["last_sign_in_ip"] %></dd>
          </div>
        <% end %>
        <% if @user.metadata["last_db_activity"].present? %>
          <div>
            <dt class="text-xs text-gray-500 uppercase">Last DB Activity</dt>
            <dd class="text-sm text-gray-900 mt-1"><%= @user.metadata["last_db_activity"] %></dd>
          </div>
        <% end %>
      <% end %>
    </dl>
  </div>

  <!-- Database Usage Summary -->
  <% if @user.database_username.present? %>
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-sm font-medium text-gray-700 mb-4">Database Usage</h2>
      <% if @days_active.to_i > 0 %>
        <div class="grid grid-cols-3 gap-4">
          <div class="border border-navy/20 rounded-lg p-4 text-center">
            <div class="text-xs text-gray-500 mb-1">Days Active</div>
            <div class="text-xl font-bold"><%= number_with_delimiter(@days_active) %></div>
          </div>
          <div class="border border-navy/20 rounded-lg p-4 text-center">
            <div class="text-xs text-gray-500 mb-1">First Active</div>
            <div class="text-xl font-bold"><%= @first_active.strftime("%b %d, %Y") %></div>
          </div>
          <div class="border border-navy/20 rounded-lg p-4 text-center">
            <div class="text-xs text-gray-500 mb-1">Last Active</div>
            <div class="text-xl font-bold"><%= @last_active.strftime("%b %d, %Y") %></div>
          </div>
        </div>
        <p class="text-xs text-gray-400 mt-3">
          Based on direct PostgreSQL connections. Does not include SQL Playground queries.
          <%= link_to "View usage dashboard", admin_usage_path, class: "underline hover:text-gray-600" %>
        </p>
      <% else %>
        <p class="text-sm text-gray-500">No database usage recorded yet.</p>
      <% end %>
    </div>
  <% end %>
</div>
