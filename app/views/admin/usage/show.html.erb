<div class="mx-auto max-w-6xl">
  <!-- Header -->
  <div class="flex justify-between items-center mb-8">
    <%= link_to "Back to Usage", admin_usage_path, class: "px-4 py-2 bg-gray-200 text-gray-700 text-sm font-medium rounded-md hover:bg-gray-300" %>
    <h1 class="text-2xl font-bold text-gray-900">Daily Usage: <%= @formatted_date %></h1>
    <%= link_to "Full PgBadger Report", @pgbadger_url, target: "_blank", class: "px-4 py-2 bg-navy text-white text-sm font-medium rounded-md hover:bg-navy/90" %>
  </div>

  <% if @users.present? %>
    <!-- Summary Stats -->
    <div class="bg-white shadow rounded-lg p-6 mb-6">
      <h2 class="text-sm font-medium text-gray-700 mb-4">Daily Summary Statistics</h2>
      <div class="grid grid-cols-3 gap-4">
        <div class="border border-navy/20 rounded-lg p-4 text-center">
          <div class="text-sm text-gray-500 mb-1">Total Users</div>
          <div class="text-xl font-bold"><%= number_with_delimiter(@stats[:total_users]) %></div>
        </div>
        <div class="border border-navy/20 rounded-lg p-4 text-center">
          <div class="text-sm text-gray-500 mb-1">Total Queries</div>
          <div class="text-xl font-bold"><%= number_with_delimiter(@stats[:total_queries]) %></div>
        </div>
        <div class="border border-navy/20 rounded-lg p-4 text-center">
          <div class="text-sm text-gray-500 mb-1">Avg Queries per User</div>
          <div class="text-xl font-bold"><%= number_with_precision(@stats[:avg_queries_per_user], precision: 0) %></div>
        </div>
      </div>
    </div>

    <!-- User Activity Table -->
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="px-6 py-4 flex justify-between items-center border-b border-navy/20">
        <h2 class="text-sm font-medium text-navy">User Activity Details</h2>
        <span class="text-xs text-gray-500">Sorted by query count (highest first)</span>
      </div>
      <table class="min-w-full divide-y divide-navy/10">
        <thead class="bg-navy/5">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">#</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Username</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Query Count</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">% of Total</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Total Duration (ms)</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">% of Total Duration</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Avg Duration (ms)</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-navy/10">
          <% @users.each_with_index do |user, index| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-3 text-sm text-gray-400"><%= index + 1 %></td>
              <td class="px-6 py-3 text-sm font-medium text-gray-900">
                <% if (matched_user = @user_map&.fetch(user[:username], nil)) %>
                  <%= link_to user[:username], admin_user_path(matched_user), class: "text-blue-600 hover:text-blue-800 hover:underline" %>
                <% else %>
                  <%= user[:username] %>
                <% end %>
              </td>
              <td class="px-6 py-3 text-right text-sm text-gray-900"><%= number_with_delimiter(user[:query_count]) %></td>
              <td class="px-6 py-3 text-right text-sm text-gray-900">
                <%= number_with_precision(user[:query_count].to_f / @stats[:total_queries] * 100, precision: 2) %>%
              </td>
              <td class="px-6 py-3 text-right text-sm text-gray-900"><%= number_with_delimiter(user[:total_duration_ms].to_i) %></td>
              <td class="px-6 py-3 text-right text-sm text-gray-900">
                <%= number_with_precision(user[:total_duration_ms].to_f / @stats[:total_duration] * 100, precision: 2) %>%
              </td>
              <td class="px-6 py-3 text-right text-sm text-gray-900"><%= number_with_precision(user[:avg_query_duration_ms], precision: 1) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <div class="px-6 py-3 bg-navy/5 border-t border-navy/20">
        <span class="text-xs text-gray-500">Data shows user activity for <%= @formatted_date %>. Users are ranked by total query count.</span>
      </div>
    </div>
  <% else %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6">
      <h3 class="text-lg font-medium text-yellow-800 mb-2">No User Data Available</h3>
      <p class="text-yellow-700">No user activity data is available for <%= @formatted_date %>.</p>
      <div class="mt-4">
        <%= link_to "Back to Usage", admin_usage_path, class: "px-4 py-2 bg-navy text-white text-sm font-medium rounded-md hover:bg-navy/90" %>
      </div>
    </div>
  <% end %>
</div>
