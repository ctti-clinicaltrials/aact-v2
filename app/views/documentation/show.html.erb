<div class="mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <%# TODO: preserve state and filters in back link %>
    <%= link_to "← Back to Documentation", documentation_index_path, class: "text-blue-600 hover:text-blue-800 hover:underline" %>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h1 class="text-2xl font-bold text-gray-900">
        <%= @doc_item.table_name %>.<%= @doc_item.column_name %>
      </h1>
      <p class="mt-1 text-sm text-gray-500">Field Documentation</p>
    </div>

    <!-- AACT Database Information -->
    <div class="px-4 py-5 sm:p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">AACT Database Information</h2>
      <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
        <div>
          <dt class="text-sm font-medium text-gray-500">Table Name</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @doc_item.table_name %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Column Name</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @doc_item.column_name %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Data Type</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @doc_item.data_type %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Nullable</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @doc_item.nullable ? "Yes" : "No" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Active</dt>
          <dd class="mt-1 text-sm">
            <% if @doc_item.active %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Yes</span>
            <% else %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">No</span>
            <% end %>
          </dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="text-sm font-medium text-gray-500">Description</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @doc_item.description || "-" %></dd>
        </div>
      </dl>
    </div>

    <% if @doc_item.ctgov_path.present? %>
      <div class="border-t border-gray-200 px-4 py-5 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">CTGov API Metadata</h2>
        <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
          <div>
            <dt class="text-sm font-medium text-gray-500">CTGov Section</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @doc_item.ctgov_section || "-" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">CTGov Module</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @doc_item.ctgov_module || "-" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">CTGov Data Point</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @doc_item.ctgov_label || "-" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">CTGov API Field Path</dt>
            <dd class="mt-1 text-sm text-gray-900 font-mono text-xs"><%= @doc_item.ctgov_path || "-" %></dd>
          </div>
          <div class="sm:col-span-2">
            <dt class="text-sm font-medium text-gray-500">CTGov Documentation URL</dt>
            <dd class="mt-1 text-sm">
              <% if @doc_item.ctgov_url.present? %>
                <%= link_to @doc_item.ctgov_url, @doc_item.ctgov_url, target: "_blank", class: "text-blue-600 hover:text-blue-800 hover:underline break-all" %>
              <% else %>
                <span class="text-gray-900">-</span>
              <% end %>
            </dd>
          </div>
        </dl>
      </div>
    <% end %>
  </div>
</div>
